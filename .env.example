# Supabase (public, safe for browser + server)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Required for server-side uploads (never expose to the client / never prefix with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# -----------------------------------------------------------------------------
# Vercel → Project → Settings → Environment Variables
# -----------------------------------------------------------------------------
# Add the three variables above for each environment you use (at minimum
# Production; add Preview if you deploy PRs). Names must match exactly.
#
# After saving, trigger a new Deployment (Redeploy) so the build and runtime
# pick up the values.
#
# Quick check on any deployed URL:
#   GET /api/health/supabase  →  { "ok": true, ... } when URL + anon key work
#
# Supabase Dashboard (same project as these keys):
#   Authentication → URL configuration → add your Vercel origins, e.g.
#     https://your-app.vercel.app
#     https://your-app-*.vercel.app   (Preview)
#   Site URL should match your primary app URL.
